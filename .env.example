APP_NAME="Motivation Engine"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://motivation.life-expat.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ─── PostgreSQL ───
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=motivation_engine
DB_USERNAME=motivation
DB_PASSWORD=

# ─── Redis ───
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ─── Twilio (WhatsApp) ───
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

# ─── Firebase Webhook ───
FIREBASE_WEBHOOK_SECRET=
FIREBASE_RECONCILE_URL=

# ─── WhatsApp Configuration ───
WHATSAPP_WARMUP_START_DATE=
WHATSAPP_DAILY_BUDGET_CENTS=2000
WHATSAPP_MONTHLY_BUDGET_CENTS=30000

# ─── Admin Alerts ───
ADMIN_ALERT_EMAIL=admin@motivation.life-expat.com
ADMIN_ALERT_PHONE=
ADMIN_ALLOWED_IPS=

# ─── Sentry Error Tracking ───
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Mail ───
MAIL_MAILER=smtp
MAIL_HOST=smtp.zoho.eu
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@motivation.life-expat.com"
MAIL_FROM_NAME="${APP_NAME}"
